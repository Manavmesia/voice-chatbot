# Copy this file to .env and fill in your values.
# Never commit the .env file — it is listed in .gitignore.

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the data directory (PDFs + ChromaDB). Defaults to ./data
DATA_DIR=./data

# ── TTS ───────────────────────────────────────────────────────────────────────
# Edge TTS voice name. See: https://speech.microsoft.com/portal/voicegallery
TTS_VOICE=en-US-EmmaMultilingualNeural
# Speaking rate adjustment (e.g. -10%, +5%)
TTS_RATE=-10%

# ── Server (used by run.sh / Docker) ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
